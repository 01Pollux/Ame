{
  "version": 6,
  "configurePresets": [
    {
      "name": "build-default",
      "hidden": true,
      "cacheVariables": {
        "Boost_NO_WARN_NEW_VERSIONS": true,
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}",
        "VCPKG_TARGET_TRIPLET": "override_vcpkg_triplets"
      }
    },

    {
      "name": "debug",
      "hidden": true,
      "inherits": "build-default",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "AME_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "inherits": "debug",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AME_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dist",
      "hidden": true,
      "inherits": "debug",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AME_BUILD_TYPE": "Dist"
      }
    },


    {
      "name": "windows-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": {
        "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
          "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
        }
      }
    },


    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "inherits": [ "windows-base", "debug" ]
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "inherits": [ "windows-base", "release" ]
    },
    {
      "name": "windows-dist",
      "displayName": "Windows Dist",
      "inherits": [ "windows-base", "dist" ]
    },

    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": [ "linux-base", "debug" ]
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "inherits": [ "linux-base", "release" ]
    },
    {
      "name": "linux-dist",
      "displayName": "Linux Dist",
      "inherits": [ "linux-base", "dist" ]
    }
  ]
}
